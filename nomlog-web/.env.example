# Same Supabase project as nomlog-app (Authentication → API URL and anon key).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Public base URL for nomlog-api (no trailing slash).
# Local: http://localhost:3001
# Production: your Render API URL, e.g. https://nomlog-api.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:3001

# Optional: server-only; do NOT expose to the browser. Only for future scripts
# or API routes that grant admin with the service role.
# SUPABASE_SERVICE_ROLE_KEY=
