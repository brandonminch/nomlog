**/.env.development
**/.env.production
**/.env.local
**/.env.sentry-build-plugin

# Claude / Cursor local overrides (may contain tokens)
.claude/settings.local.json

# Optional local tooling
.idea/
*.swp
*.swo

# Cursor debug logs
.cursor/debug*.log

# Test / coverage (if generated at root)
coverage/
