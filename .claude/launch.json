{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Nomlog API (dev)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "nomlog-api", "run", "dev:develop"],
      "port": 3001
    },
    {
      "name": "Nomlog App (Expo)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "nomlog-app", "run", "start"],
      "port": 8081
    },
    {
      "name": "Nomlog App (Web)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "nomlog-app", "run", "web"],
      "port": 8081
    }
  ]
}
