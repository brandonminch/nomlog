# API Configuration
API_URL=https://nomlog-api.onrender.com/api/v1

# Server Configuration
PORT=3001
NODE_ENV=development
API_VERSION=v1

# Supabase Configuration (required by src/config/supabase.ts)
SUPABASE_URL=your-supabase-url-here
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here
SUPABASE_ANON_KEY=your-supabase-anon-key-here

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL_NAME=gpt-3.5-turbo
# Per-user rolling token budget for OpenAI Responses API only (not embeddings). Omit or set 0 to disable.
# LLM_TOKENS_LIMIT_PER_WINDOW=500000
# Window length in seconds (default 86400 = 24h if unset or invalid).
# LLM_TOKENS_WINDOW_SECONDS=86400
# Optional: PostHog distinct_id for internal/job LLM events when user_id is null
# LLM_ANALYTICS_DISTINCT_ID=nomlog-api-internal
# Optional: max output tokens (Responses API). Summary default 900; full analysis default 8000.
# OPENAI_SUMMARY_MAX_OUTPUT_TOKENS=4000
# OPENAI_ANALYSIS_MAX_OUTPUT_TOKENS=8000
# Optional: Supabase Storage bucket for meal photos
# MEAL_PHOTO_BUCKET=meal-photos

POSTHOG_API_KEY=your-posthog-api-key-here
POSTHOG_HOST=https://us.i.posthog.com