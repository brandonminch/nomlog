# Copy to .env.development (gitignored) for develop / Supabase branch work.
# Run from repo root: pnpm --filter nomlog-api run dev:develop
#
# Values: Supabase dashboard → switch to develop branch → Settings → API

PORT=3001
NODE_ENV=development
API_VERSION=v1

SUPABASE_URL=https://your-develop-branch-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-develop-service-role-key
SUPABASE_ANON_KEY=your-develop-anon-key

OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL_NAME=gpt-3.5-turbo
# Optional: OPENAI_SUMMARY_MAX_OUTPUT_TOKENS=900
# Optional: OPENAI_ANALYSIS_MAX_OUTPUT_TOKENS=8000
# Optional: MEAL_PHOTO_BUCKET=meal-photos

# Optional: direct Postgres (migrations, scripts)
# DATABASE_URL=postgresql://...
