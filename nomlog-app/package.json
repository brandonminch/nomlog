{
  "name": "nomlog-app",
  "version": "1.0.0",
  "packageManager": "pnpm@9.15.9",
  "main": "expo-router/entry",
  "scripts": {
    "start": "EXPO_APP_ENV=development expo start",
    "start:production": "EXPO_APP_ENV=production expo start",
    "start:develop": "EXPO_APP_ENV=development expo start",
    "android": "EXPO_APP_ENV=development expo run:android",
    "android:develop": "EXPO_APP_ENV=development expo run:android",
    "android:production": "EXPO_APP_ENV=production expo run:android",
    "ios": "EXPO_APP_ENV=development expo run:ios",
    "ios:develop": "EXPO_APP_ENV=development expo run:ios",
    "ios:production": "EXPO_APP_ENV=production expo run:ios",
    "ios:dev": "EXPO_APP_ENV=development expo run:ios --configuration Debug",
    "ios:simulator": "EXPO_APP_ENV=development expo run:ios --simulator",
    "ios:device:release": "EXPO_APP_ENV=development expo run:ios --device --configuration Release",
    "ios:device:production:release": "EXPO_APP_ENV=production expo run:ios --device --configuration Release",
    "prebuild": "expo prebuild",
    "prebuild:ios:production": "CI=1 EXPO_APP_ENV=production expo prebuild --platform ios --clean",
    "build:local:ios": "eas build --profile preview --platform ios --local",
    "build:local:android": "eas build --profile preview --platform android --local",
    "build:eas:ios": "eas build --profile preview --platform ios",
    "build:eas:android": "eas build --profile preview --platform android",
    "lint": "expo lint",
    "lint:fix": "expo lint --fix",
    "type-check": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "web": "EXPO_APP_ENV=development expo start --web",
    "web:develop": "EXPO_APP_ENV=development expo start --web",
    "web:production": "EXPO_APP_ENV=production expo start --web",
    "export:web": "expo export --platform web"
  },
  "dependencies": {
    "@expo/config-plugins": "^10.1.2",
    "@expo/vector-icons": "^14.1.0",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-native-community/datetimepicker": "8.4.1",
    "@react-native-picker/picker": "^2.11.4",
    "@react-navigation/native": "^7.1.6",
    "@react-navigation/native-stack": "^7.3.10",
    "@sentry/react-native": "~6.14.0",
    "@supabase/supabase-js": "^2.39.3",
    "@tanstack/react-query": "^5.85.5",
    "expo": "~53.0.22",
    "expo-apple-authentication": "~7.2.4",
    "expo-application": "~6.1.5",
    "expo-auth-session": "~6.2.1",
    "expo-constants": "~17.1.8",
    "expo-crypto": "~14.1.5",
    "expo-file-system": "~18.1.11",
    "expo-font": "~13.3.2",
    "expo-image-manipulator": "~13.1.7",
    "expo-image-picker": "55.0.18",
    "expo-linear-gradient": "~14.1.5",
    "expo-linking": "~7.1.7",
    "expo-notifications": "~0.31.5",
    "expo-router": "~5.1.5",
    "expo-splash-screen": "~0.30.10",
    "expo-status-bar": "~2.2.3",
    "expo-web-browser": "~14.2.0",
    "lottie-react-native": "7.2.2",
    "lucide-react-native": "^0.544.0",
    "nomlog-health": "file:./modules/nomlog-health",
    "onesignal-expo-plugin": "^2.0.3",
    "posthog-react-native": "^4.41.1",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.5",
    "react-native-calendars": "^1.1314.0",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-onesignal": "^5.2.13",
    "react-native-progress-wheel": "^2.1.0",
    "react-native-reanimated": "~3.17.4",
    "react-native-reanimated-carousel": "^4.0.3",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-svg": "15.11.2",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-web": "^0.20.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~19.0.10",
    "dotenv": "^16.4.7",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~9.2.0",
    "typescript": "~5.8.3"
  },
  "private": true
}
