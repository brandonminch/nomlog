# Copy to .env.production and fill with production (main Supabase branch) values.
# Use with: yarn start:production

EXPO_PUBLIC_API_URL=https://your-production-api.example.com
EXPO_PUBLIC_SUPABASE_URL=https://your-prod-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-production-anon-key
# Optional: defaults to "meal-photos" if omitted
# EXPO_PUBLIC_MEAL_PHOTO_BUCKET=meal-photos

# Supabase Social Auth (Google)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

EXPO_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# Build-time Sentry (source maps): use EAS Secret SENTRY_AUTH_TOKEN for cloud builds, or
# copy .env.sentry-build-plugin.example → .env.sentry-build-plugin for local eas build --local.
