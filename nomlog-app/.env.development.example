# Copy to .env.development and fill with develop / preview Supabase branch values.
# Use with: pnpm --filter nomlog-app run start:develop
# Credentials: Supabase dashboard → switch to develop branch → Settings → API

EXPO_PUBLIC_API_URL=http://localhost:3001
EXPO_PUBLIC_SUPABASE_URL=https://your-develop-branch-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-develop-branch-anon-key
# Optional: defaults to "meal-photos" if omitted
# EXPO_PUBLIC_MEAL_PHOTO_BUCKET=meal-photos

# Sentry (runtime DSN; create project at sentry.io)
EXPO_PUBLIC_SENTRY_DSN=
# Used by @sentry/react-native/expo during prebuild/EAS — not bundled into the app
SENTRY_ORG=
SENTRY_PROJECT=
# Build-time uploads: eas secret:create --name SENTRY_AUTH_TOKEN --value <token>
