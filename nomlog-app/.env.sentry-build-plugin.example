# Copy to .env.sentry-build-plugin and fill in. Loaded by app.config.js so prebuild writes
# ios/sentry.properties + android with defaults.org / defaults.project (required for Xcode).
# Also used by Sentry's source-map upload script.
#
# https://docs.sentry.io/platforms/react-native/manual-setup/expo/

SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
# Optional; defaults to https://sentry.io/
# SENTRY_URL=https://sentry.io/

# To turn Sentry CLI uploads back on: remove SENTRY_DISABLE_AUTO_UPLOAD from eas.json
# (development / preview / production env) and from ios/.xcode.env, or set it to false.
